# ============================================================
# VARIÁVEIS DE AMBIENTE — Best of Opera App2
# Copie para .env e preencha os valores reais
# ============================================================

# --- BANCO DE DADOS (obrigatório em produção) ---
DATABASE_URL=postgresql://postgres:senha@host:5432/railway
# Local dev: sqlite:///./editor.db ou sqlite:///./best_of_opera.db

# --- STORAGE (obrigatório em produção) ---
R2_ACCOUNT_ID=seu_account_id
R2_ACCESS_KEY_ID=sua_access_key
R2_SECRET_ACCESS_KEY=sua_secret_key
R2_BUCKET_NAME=best-of-opera
STORAGE_PATH=/tmp/editor_storage

# --- APIs EXTERNAS ---
GEMINI_API_KEY=AIza...             # obrigatório — transcrição e letra (app-editor)
ANTHROPIC_API_KEY=sk-ant-...       # obrigatório — geração de conteúdo (app-redator)
GOOGLE_TRANSLATE_API_KEY=AIza...   # obrigatório — tradução de letras
GENIUS_API_TOKEN=                  # opcional — busca de letras via Genius
YOUTUBE_API_KEY=AIza...            # obrigatório — busca YouTube (app-curadoria)

# URLs internas dos serviços
REDATOR_API_URL=https://app-production-870c.up.railway.app
CURADORIA_API_URL=https://curadoria-backend-production.up.railway.app
COBALT_API_URL=https://api.cobalt.tools  # opcional — download cobalt (fallback yt-dlp se vazio)

# --- CONFIG GERAL ---
SECRET_KEY=dev-secret-key-change-in-production
CORS_ORIGINS=["http://localhost:3000","https://portal-production-4304.up.railway.app"]
MAX_VIDEO_SIZE_MB=500
EXPORT_PATH=                        # pasta local de export (ex: iCloud Drive), opcional

# --- MONITORAMENTO ---
SENTRY_DSN=                         # opcional — se vazio, Sentry desativado silenciosamente
